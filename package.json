{
    "name": "@diia-inhouse/env",
    "version": "2.8.5",
    "description": "Environment checking service",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-pkg-env",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsc",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint --fix . && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "dependencies": {
        "@diia-inhouse/diia-metrics": "6.5.8",
        "dotenv-flow": "4.1.0",
        "lodash.get": "4.4.2"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/diia-logger": "3.17.3",
        "@diia-inhouse/errors": "1.18.9",
        "@diia-inhouse/eslint-config": "8.8.0",
        "@diia-inhouse/test": "7.3.9",
        "@diia-inhouse/types": "11.6.0",
        "@types/dotenv-flow": "3.3.3",
        "@types/lodash.get": "4.4.9",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "eslint": "9.39.2",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "rimraf": "6.1.3",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18"
    },
    "peerDependencies": {
        "@diia-inhouse/types": ">=4.4.1"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "jest": {
        "preset": "@diia-inhouse/configs/dist/jest"
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
