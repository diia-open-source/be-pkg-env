{
    "name": "@diia-inhouse/env",
    "version": "3.3.3",
    "type": "module",
    "description": "Environment checking service",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "repository": "https://github.com/diia-open-source/be-pkg-env",
    "author": "Diia",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsdown",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "oxlint && oxfmt --check .",
        "lint-fix": "oxlint --fix && oxfmt .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "dependencies": {
        "@diia-inhouse/diia-metrics": "7.1.6",
        "dotenv-flow": "4.1.0",
        "lodash.get": "4.4.2"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "7.0.0",
        "@diia-inhouse/diia-logger": "4.3.0",
        "@diia-inhouse/errors": "2.1.1",
        "@diia-inhouse/oxc-config": "1.10.0",
        "@diia-inhouse/test": "8.2.2",
        "@diia-inhouse/types": "13.2.0",
        "@types/dotenv-flow": "3.3.3",
        "@types/lodash.get": "4.4.9",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/ui": "4.1.5",
        "lockfile-lint": "5.0.0",
        "madge": "8.0.0",
        "oxfmt": "0.48.0",
        "oxlint": "1.63.0",
        "oxlint-tsgolint": "0.22.1",
        "rimraf": "6.1.3",
        "tsdown": "0.22.0",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.5"
    },
    "peerDependencies": {
        "@diia-inhouse/types": ">=13.1.1"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "madge": {
        "tsConfig": "./tsconfig.json"
    },
    "license": "SEE LICENSE IN LICENSE.md"
}
